#!/bin/bash
set -x

# Create shell profile file with k3s environment variables,
# kubectl bash completion and alias.
cat << 'EOF' > /etc/profile.d/k3s.sh
export KUBECONFIG=/etc/rancher/k3s/k3s.yaml
export CRI_CONFIG_FILE=/var/lib/rancher/k3s/agent/etc/crictl.yaml
export CONTAINERD_ADDRESS=/run/k3s/containerd/containerd.sock
source <(kubectl completion bash 2>/dev/null)
alias k=kubectl
complete -F __start_kubectl k
EOF

# Create k3s config directory
mkdir -p /etc/rancher/k3s/
cat <<EOF > /etc/rancher/k3s/config.yaml
token: "${token}"
tls-san:
  - ${lb_ip}
write-kubeconfig-mode: "0644"
EOF

# If this is not the first server node, add server URL with loadbalancer IP to config file.
# k3s does not have a separate supervisor port; joining uses the standard API port 6443.
if [ "${count}" -gt "0" ]; then
  echo "server: https://${lb_ip}:6443" >> /etc/rancher/k3s/config.yaml
fi

# k3s requires the explicit --cluster-init flag (or config key) to enable embedded etcd HA
if [ "${count}" -eq "0" ]; then
  echo "cluster-init: true" >> /etc/rancher/k3s/config.yaml
fi

# Set k3s version if specified 
if [ ! -z "${k3s_version}" ]; then
  export INSTALL_K3S_VERSION="${k3s_version}"
fi

# Install k3s server.
curl -sfL https://get.k3s.io | sh -s - server

# Enable and start the k3s server service.
systemctl enable k3s
systemctl start k3s

# If this is the first server node, install Rancher 
if [ "${count}" -eq "0" ]; then

  # Set environment variables for Helm and kubectl
  export KUBECONFIG=/etc/rancher/k3s/k3s.yaml
  export HOME=/root

  # Install Helm
  curl https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash

  # # If user defines rancher prime helm repository, and chart version exists within it, use the prime repository;
  # otherwise fall back to rancher-latest repository
  repo=rancher-latest/rancher
  if [ -n "${rancher_chart_repo}" ]; then
    helm repo add rancher-prime ${rancher_chart_repo}
    helm repo update

    # Check if the specified rancher version exists in the rancher-prime repository
    # Rancher Prime >= 2.13.1 uses rancher-prime chart name, check for both possible names
    if helm search repo rancher-prime/rancher-prime --version ${rancher_version} --fail-on-no-result; then
      repo=rancher-prime/rancher-prime
    elif helm search repo rancher-prime/rancher --version ${rancher_version} --fail-on-no-result; then
      repo=rancher-prime/rancher
    fi
  fi

  helm repo add jetstack https://charts.jetstack.io
  helm repo add rancher-latest https://releases.rancher.com/server-charts/latest
  helm repo update

  # Wait for the k3s traefik ingress controller to be ready before installing cert-manager
  while ! kubectl get nodes 2>/dev/null | grep -q " Ready"; do
    sleep 5
  done
  while ! kubectl -n kube-system rollout status deploy/traefik 2>/dev/null; do
    sleep 5
  done

  # Install cert-manager
  helm install cert-manager jetstack/cert-manager --namespace cert-manager --create-namespace --set crds.enabled=true

  # Wait for the cert-manager webhook to be ready
  while ! kubectl -n cert-manager rollout status deploy/cert-manager-webhook; do
    sleep 5
  done

  # Install Rancher.
  helm install rancher $repo --namespace cattle-system --create-namespace --set hostname=${lb_ip}.nip.io --version ${rancher_version} --set bootstrapPassword="${admin_password}" --set ingress.ingressClassName=traefik
fi
