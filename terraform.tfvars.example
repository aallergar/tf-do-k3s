# DigitalOcean API token
do_token = "your_token"

# Admin password to access Rancher
admin_password = "administrator"

# Resources will be prefixed with this to avoid clashing names
prefix = "myname-tf-do-k3s"

# k3s version to install (leave commented for latest stable)
# k3s_version = "v1.31.4+k3s1"

# Rancher version to install
# rancher_version = "v2.10.2"

# Count of k3s server nodes (use 1 for dev, 3 for HA with embedded etcd)
count_server_nodes = "1"

# Count of k3s agent nodes
count_agent_nodes = "0"

# Region where nodes should be created
region = "lon1"

# Droplet size for server nodes (min 4 vCPU / 8 GB for Rancher)
server_size = "s-4vcpu-8gb"

# Droplet size for agent nodes
agent_size = "s-2vcpu-4gb"

# Image of nodes
image = "ubuntu-22-04-x64"

# User for image
user = "root"

# Chart repository for the Rancher Prime chart, falls back to rancher-latest
rancher_chart_repo = ""

# DigitalOcean ssh-keyid
# ssh_keys = [ "your_key_id" ]
# Retrieve using: `curl -s -X GET -H "Content-Type: application/json" -H "Authorization: Bearer $DIGITALOCEAN_TOKEN" "https://api.digitalocean.com/v2/account/keys?per_page=200" | jq -r '.ssh_keys[] | select(.name=="YOUR_KEY_NAME") | .id'`
# If this is not specified, you will get an email with the root password
ssh_keys = []
